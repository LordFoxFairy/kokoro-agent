# Template — copy to .env (gitignored) and fill in real values.

# Default chat model as "provider:model".
KOKORO_MODEL=anthropic:claude-sonnet-4-6

# Credentials for an OpenAI-compatible provider (leave blank if using Anthropic).
OPENAI_BASE_URL=
OPENAI_API_KEY=

# Credentials for Anthropic (leave blank if using an OpenAI-compatible provider).
# ANTHROPIC_BASE_URL=
# ANTHROPIC_API_KEY=

# Set to 1 to disable streaming.
KOKORO_DISABLE_STREAMING=

# Optional offline fallback — deterministic fake model, no credentials needed.
# KOKORO_LOCAL_FAKE_MODEL=1
